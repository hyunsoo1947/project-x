{
  "name": "routebox-shipments-api",
  "version": "1.42.0",
  "description": "Routebox shipments REST API. Express + Postgres + SQS.",
  "private": true,
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0 <19.0.0"
  },
  "scripts": {
    "start":   "node src/index.js",
    "dev":     "node --watch src/index.js",
    "test":    "jest --runInBand --testTimeout=30000",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=routes",
    "lint":    "eslint src test",
    "lint:fix": "eslint src test --fix"
  },
  "dependencies": {
    "aws-sdk":       "^2.1450.0",
    "body-parser":   "^1.20.2",
    "csv-stringify": "^6.4.4",
    "dotenv":        "^16.3.1",
    "express":       "^4.18.2",
    "jsonwebtoken":  "^9.0.2",
    "pg":            "^8.11.3",
    "pg-cursor":     "^2.10.3",
    "uuid":          "^9.0.1",
    "winston":       "^3.10.0"
  },
  "devDependencies": {
    "eslint":         "^8.50.0",
    "jest":           "^29.7.0",
    "supertest":      "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.js"]
  }
}
